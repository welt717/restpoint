{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "API Gateway for   RestPoint    MMS",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx ts-node server.ts",
    "dev:watch": "nodemon --watch . --ext ts --exec npx ts-node server.ts",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "http-proxy": "^1.18.1",
    "http-proxy-middleware": "3.0.3",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "object-assign": "^4.1.1",
    "rate-limit-redis": "^4.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^6.0.0",
    "@types/http-proxy-middleware": "^1.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.0",
    "nodemon": "^3.1.9",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
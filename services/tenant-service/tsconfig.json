{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false
  },
  "include": [
    "*.ts",
    "src/**/*",
    "config/**/*",
    "controllers/**/*",
    "middlewares/**/*",
    "models/**/*",
    "routes/**/*",
    "services/**/*",
    "types/**/*",
    "utils/**/*",
    "scripts/**/*",
    "migrations/**/*"
  ],
  "exclude": ["node_modules", "dist", "uploads"]
}
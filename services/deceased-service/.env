PORT=8103
NODE_ENV=development

# Database Configuration - Use localhost for local development
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root

# Redis Configuration - Use localhost for local development
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_CACHE_TTL=3600
REDIS_MAX_RETRIES=3

# JWT Configuration
JWT_SECRET=supersecretkey_change_in_production

# Queue Configuration
QUEUE_CONCURRENCY=5
QUEUE_MAX_JOBS=1000

# Export Configuration
EXCEL_MAX_ROWS=10000
EXPORT_TIMEOUT=300000
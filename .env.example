# ============================================
# REST POINT - ENVIRONMENT TEMPLATE
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env files to version control.
# ============================================

# DATABASE
DB_HOST=mariadb
DB_PORT=3306
DB_PASSWORD=change_me_in_production
DB_USER=root

# REDIS
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# APPLICATION
NODE_ENV=development
APP_NAME=Restpoint MMS
APP_PORT=8080

# SECURITY - Generate unique secrets for production
JWT_SECRET=generate_a_random_64_character_hex_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=generate_another_random_64_character_hex_string
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=generate_a_random_session_secret
BCRYPT_ROUNDS=12

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_METHODS=GET,POST,PUT,PATCH,DELETE
CORS_CREDENTIALS=true

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_REQUESTS=5

# FILE STORAGE
UPLOAD_MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,docx,xls

# EMAIL
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-email@restpoint.co.ke
SMTP_PASSWORD=

# SERVICES PORTS
API_GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5001
TENANT_SERVICE_PORT=5002
DECEASED_SERVICE_PORT=5003
MARKETPLACE_SERVICE_PORT=5004
INVOICE_SERVICE_PORT=5005
COFFIN_SERVICE_PORT=5006
DOCUMENTS_SERVICE_PORT=5007
EDOCUMENTS_SERVICE_PORT=5008
ANALYTICS_SERVICE_PORT=5009
CALENDER_SERVICE_PORT=5010
MPESA_SERVICE_PORT=5011
NOTIFICATION_SERVICE_PORT=5111
QR_CODE_SERVICE_PORT=5012
SOCKETIO_SERVICE_PORT=5013
VISITORS_SERVICE_PORT=5014
BODYCHECKOUT_SERVICE_PORT=5015
EXTRA_SERVICES_PORT=5016
UPDATES_SERVICE_PORT=5017
CALL_SERVICE_PORT=5018
PORTAL_SERVICE_PORT=5019
CHEMICAL_SERVICE_PORT=5105

# MPESA (Sandbox)
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=

# RESEND EMAIL
RESEND_API_KEY=

# LOGGING
LOG_LEVEL=info
AUDIT_LOGGING=true
LOG_RETENTION_DAYS=90

# BACKUPS
BACKUP_ENABLED=true
BACKUP_CRON="0 2 * * *"
BACKUP_RETENTION_DAYS=90
{
  "name": "@montezuma/calendar-service",
  "version": "2.0.0",
  "description": "Montezuma Mortuary SaaS - Multi-tenant Calendar Service with event management",
  "main": "dist/server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx server.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev:watch": "tsx watch server.ts",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "check-migrations": "node check-migrations.js",
    "check-setup": "npm run check-migrations",
    "test:health": "curl http://localhost:8104/health",
    "test:events": "curl http://localhost:8104/api/v1/calendar/events -H 'x-tenant-slug: test'"
  },
  "dependencies": {
    "express": "^5.1.0",
    "cors": "^2.8.5",
    "helmet": "^8.1.0",
    "dotenv": "^17.2.0",
    "mysql2": "^3.15.2",
    "bcrypt": "^6.0.0",
    "jsonwebtoken": "^9.0.2",
    "object-assign": "^4.1.1",
    "winston": "^3.18.3",
    "ioredis": "^5.8.2",
    "express-async-handler": "^1.2.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2"
  },
  "keywords": [
    "calendar",
    "events",
    "tenant",
    "saas",
    "mortuary",
    "rest-api"
  ]
}

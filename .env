# ============================================
# REST POINT - PRODUCTION ENVIRONMENT
# For use with EXISTING shared-db & redis
# ============================================

# DATABASE - Pointing to existing shared-db
DB_HOST=shared-db
DB_PORT=3306
DB_PASSWORD=root
DB_USER=root

# REDIS - Pointing to existing redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==========================================
# APPLICATION
# ==========================================
NODE_ENV=production
APP_NAME=Rest Point
APP_PORT=8080
APP_URL=https://restpoint.co.ke
HOST=0.0.0.0

# ==========================================
# SECURITY
# ==========================================
JWT_SECRET=9e4f0d8f4b2c7a1d9f8e3b5a6c7d8e9f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=7d8c9b0a1f2e3d4c5b6a798887766554433221100ffeeddccbb55449988776655
JWT_REFRESH_EXPIRES_IN=7d
SESSION_SECRET=4a8f7c6b5d4e3f2a1b0c9d8e7f6a5b4c3d2e1f0987654321123456789abcdef
BCRYPT_ROUNDS=14
DATABASE_SSL=true
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=30

# ==========================================
# CORS
# ==========================================
CORS_ORIGIN=https://restpoint.co.ke,https://www.restpoint.co.ke,https://app.restpoint.co.ke
CORS_METHODS=GET,POST,PUT,PATCH,DELETE
CORS_CREDENTIALS=true

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_REQUESTS=5

# ==========================================
# FILE STORAGE
# ==========================================
UPLOAD_MAX_FILE_SIZE_MB=100
ALLOWED_FILE_TYPES=pdf,jpg,jpeg,png,docx,xls

# ==========================================
# EMAIL
# ==========================================
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=info@restpoint.co.ke
SMTP_PASSWORD=
SMTP_SECURE=true

# ==========================================
# AUDIT & LOGGING
# ==========================================
LOG_LEVEL=info
AUDIT_LOGGING=true
LOG_RETENTION_DAYS=365

# ==========================================
# BACKUPS
# ==========================================
BACKUP_ENABLED=true
BACKUP_CRON=0 2 * * *
BACKUP_RETENTION_DAYS=90

# ==========================================
# ENCRYPTION
# ==========================================
DATA_ENCRYPTION_KEY=GENERATE_64_CHARACTER_HEX_KEY
FIELD_ENCRYPTION_KEY=GENERATE_ANOTHER_64_CHARACTER_HEX_KEY

# ==========================================
# MFA
# ==========================================
MFA_ENABLED=true
TOTP_ISSUER=RestPoint

# ==========================================
# HEALTH CHECKS
# ==========================================
HEALTHCHECK_ENABLED=true

# ==========================================
# API
# ==========================================
API_VERSION=v2
API_TIMEOUT_MS=30000
API_PORT=5000
API_BASE_URL=http://restpoint-gateway:5000
FRONTEND_URL=https://app.restpoint.co.ke

# ==========================================
# JWT
# ==========================================
JWT_SECRET=RestPointJWTSecret2024ChangeMeInProduction
JWT_EXPIRES_IN=7d


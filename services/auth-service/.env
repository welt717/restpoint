# Server
PORT=8001
NODE_ENV=development

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=root
DB_NAME=master_db
DB_PORT=3306

# JWT Secrets
JWT_SECRET=your-super-secret-jwt-key-change-this
REFRESH_SECRET=your-super-secret-refresh-key-change-this

# Cookie Settings
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100